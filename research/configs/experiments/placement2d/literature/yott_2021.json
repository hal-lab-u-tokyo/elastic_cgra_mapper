{
  "name": "placement2d_yott_2021",
  "problem_type": "placement2d",
  "evaluation_mode": "placement_only",
  "mode": "placement2d_fixed_ii",
  "result_group": "placement2d/literature/yott_2021",
  "mapping_bin": "build/mapping",
  "benchmark_sets": [
    {
      "name": "yott_2021",
      "benchmark_root": "benchmark/literature/yott_cases2021_source_order_normalized",
      "benchmarks": [
        "mac", "simple", "horner_bs", "mults1", "arf", "conv3",
        "motion_vec", "fir2", "fir1", "fdback_pts", "k4n4op", "h2v2_smo",
        "cosine1", "ewf", "Cplx8", "Fir16", "cosine2", "FilterRGB",
        "collapse_pyr", "interpolate", "w_bmp_head", "matmul", "invert_matrix"
      ]
    }
  ],
  "architectures": [
    {
      "name": "fit_io_no_corners",
      "template": "research/configs/arch_templates/mesh_10x10_default.json",
      "auto_grid": {
        "policy": "cpu_mapping_yoto_yott_fit_structural_io",
        "margin": 0
      },
      "memory_io": "perimeter_no_corners",
      "network_type": "one_hop_axis2",
      "ii": 1
    }
  ],
  "mappers": [
    {
      "name": "yoto",
      "mapper_config": "research/configs/mapper/placement2d/yoto.json"
    },
    {
      "name": "yott",
      "mapper_config": "research/configs/mapper/placement2d/yott.json"
    },
    {
      "name": "yott_core",
      "mapper_config": "research/configs/mapper/placement2d/yott_core.json"
    },
    {
      "name": "yott_core_repair",
      "mapper_config": "research/configs/mapper/placement2d/yott_core_repair.json"
    },
    {
      "name": "vpr_bb",
      "runner": "vpr",
      "vpr_bin": "${VPR_BIN:-third_party/vtr/build/vpr/vpr}",
      "arch_xml": "${VPR_ARCH_XML:-third_party/vtr/vtr_flow/arch/timing/k6_N10_40nm.xml}",
      "pack_capacity": 1,
      "fixed_layout_to_arch": true,
      "fixed_layout_io_corners": false,
      "absorb_buffer_luts": false,
      "protect_internal_buffer_luts": false,
      "output_lut_io_pads": true,
      "const_gen_inference": "comb",
      "place_algorithm": "bounding_box",
      "vpr_extra_args": ["--inner_num", "7"],
      "seed": 1,
      "place_all_ops": true,
      "allow_missing": false
    }
  ],
  "timeout_sec": 180,
  "parallel_num": 1,
  "mii_missing_distance_policy": "self_loop"
}
