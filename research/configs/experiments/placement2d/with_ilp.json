{
  "name": "placement2d_with_ilp",
  "problem_type": "placement2d",
  "evaluation_mode": "placement_only",
  "mode": "placement2d_fixed_ii",
  "result_group": "placement2d/with_ilp",
  "mapping_bin": "build/mapping",
  "benchmark_sets": [
    {
      "name": "lisa_small",
      "benchmark_root": "benchmark/literature/traversal_yott_normalized/lisa/dac",
      "benchmarks": ["bicg", "gemm", "mvt", "symm"]
    },
    {
      "name": "m_bench_small",
      "benchmark_root": "benchmark/literature/traversal_yott_normalized/m_bench/dac",
      "benchmarks": ["arf", "conv3", "mac", "mults1", "simple"]
    }
  ],
  "architectures": [
    {
      "name": "one_hop_perimeter_no_corners_io",
      "template": "research/configs/arch_templates/mesh_10x10_default.json",
      "auto_grid": {"policy": "ceil_sqrt_non_io_plus_2"},
      "memory_io": "perimeter_no_corners",
      "network_type": "one_hop_axis2",
      "ii": 1
    }
  ],
  "mappers": [
    {
      "name": "ilp",
      "mapper_config": "research/configs/mapper/placement2d/ilp.json"
    },
    {
      "name": "yoto_100",
      "mapper_config": "research/configs/mapper/placement2d/yoto.json",
      "algorithm_overrides": {"max_trials": 100}
    },
    {
      "name": "yott_100",
      "mapper_config": "research/configs/mapper/placement2d/yott.json",
      "algorithm_overrides": {"max_trials": 100}
    },
    {
      "name": "yott_core_100",
      "mapper_config": "research/configs/mapper/placement2d/yott_core.json",
      "algorithm_overrides": {"max_trials": 100}
    }
  ],
  "timeout_sec": 120,
  "parallel_num": 1,
  "mii_missing_distance_policy": "self_loop"
}
