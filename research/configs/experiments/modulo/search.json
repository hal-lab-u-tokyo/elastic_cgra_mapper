{
  "name": "modulo_search",
  "problem_type": "modulo",
  "mode": "modulo_default_ii_sweep",
  "result_group": "modulo/search",
  "mapping_bin": "/home/ubuntu/elastic_cgra_mapper/build/mapping",
  "benchmark_sets": [
    {
      "name": "quick_smoke",
